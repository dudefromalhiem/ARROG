rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isBootstrapOwner() {
      return isSignedIn() && (
        request.auth.token.email == 'jaimejoselaureano@gmail.com' ||
        request.auth.token.email == 'dudefromalhiem@gmail.com'
      );
    }

    function isOwnerFromRolesDoc() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/config/roles) &&
        ('owners' in get(/databases/$(database)/documents/config/roles).data) &&
        request.auth.token.email in get(/databases/$(database)/documents/config/roles).data.owners;
    }

    function isOwnerUser() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isOwner == true;
    }

    function isOwnerActor() {
      return isBootstrapOwner() || isOwnerFromRolesDoc() || isOwnerUser();
    }

    function getUserRole() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role is string
              ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
              : 'user'
          )
        : 'user';
    }

    function getUserLevel() {
      let role = getUserRole();
      return role == 'owner' ? 100 :
        role == 'chief_admin' ? 90 :
        role == 'admin' ? 80 :
        role == 'moderator' ? 70 :
        role == 'contributor' ? 60 :
        40; // Default level for invalid roles
    }
    // Map new 11-role system to permission levels
    function getRolePriority(role) {
      return role == 'owner' ? 100 :
        role == 'chief_administrator' ? 95 :
        role == 'chief_of_moderation' ? 90 :
        role == 'deputy_chief_administrator' ? 85 :
        role == 'deputy_chief_of_moderation' ? 80 :
        role == 'senior_administrator' ? 75 :
        role == 'senior_moderator' ? 70 :
        role == 'administrator' ? 65 :
        role == 'moderator' ? 60 :
        role == 'contributor' ? 50 :
        role == 'site_member' ? 30 :
        role == 'newbie' ? 20 :
        0;
    }

    // Check if user has at least the required role level
    function isAtLeastRole(requiredLevel) {
      let role = getUserRole();
      return getRolePriority(role) >= requiredLevel;
    }

    function isContributorGranted() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.contributorGranted == true;
    }

    function canCreateEditPages() {
      let level = getUserLevel();
      let role = getUserRole();
      let contributorGranted = isContributorGranted() || role == 'contributor' || role == 'moderator' || role == 'admin' || role == 'chief_admin';
      return isOwnerActor() ||
             role == 'chief_admin' ||
             role == 'admin' ||
             role == 'moderator' ||
             role == 'contributor' ||
             level == 6 ||
             level == 4 ||
             (level == 5 && contributorGranted);
    }

    function canModerate() {
      let level = getUserLevel();
      let role = getUserRole();

      // Fallback: consider the actor listed in config/roles (owners/admins/mods)
      // as having moderation privileges when the users/{uid} document is out-of-sync.
      let email = isSignedIn() ? request.auth.token.email : '';
      let listedInRolesDoc = isSignedIn() && exists(/databases/$(database)/documents/config/roles) && (
        (('owners' in get(/databases/$(database)/documents/config/roles).data) &&
         email in get(/databases/$(database)/documents/config/roles).data.owners) ||
        (('admins' in get(/databases/$(database)/documents/config/roles).data) &&
         email in get(/databases/$(database)/documents/config/roles).data.admins) ||
        (('mods' in get(/databases/$(database)/documents/config/roles).data) &&
         email in get(/databases/$(database)/documents/config/roles).data.mods)
      );

      return isOwnerActor() || role == 'moderator' || role == 'admin' || role == 'chief_admin' || level >= 5 || listedInRolesDoc;
    }

    function canManageUsersRoles() {
      let level = getUserLevel();
      let role = getUserRole();
      return isOwnerActor() || role == 'admin' || role == 'chief_admin' || level == 6;
    }

    function isAdminUser() {
      let level = getUserLevel();
      return isOwnerActor() || level == 6;
    }

    function canReadPublicContent() {
      return true; // Everyone can read public content
    }

    function canInteractWithContent() {
      let level = getUserLevel();
      return isOwnerUser() || level >= 3; // User level or higher
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function maxClearanceForActor() {
      return isOwnerActor() ? 6 : (getUserLevel() >= 6 ? 5 : (getUserLevel() >= 5 ? 4 : 3));
    }

    function canApproveEditorAccessOnUsersDoc() {
      return canModerate() && !canManageUsersRoles();
    }

    function hasEditorApprovalCreateFields() {
      return request.resource.data.keys().hasOnly([
        'uid',
        'email',
        'displayName',
        'submissionAccess',
        'submissionAccessStatus',
        'role',
        'roleName',
        'submissionGrantedBy',
        'submissionGrantedAt',
        'updatedAt'
      ]);
    }

    function hasEditorApprovalUpdateFields() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'email',
        'displayName',
        'submissionAccess',
        'submissionAccessStatus',
        'role',
        'roleName',
        'submissionGrantedBy',
        'submissionGrantedAt',
        'updatedAt'
      ]);
    }

    function hasValidRequestedClearance() {
      return !('clearanceLevel' in request.resource.data) ||
        (
          request.resource.data.clearanceLevel is int &&
          request.resource.data.clearanceLevel >= 1 &&
          request.resource.data.clearanceLevel <= 6
        );
    }

    function requestedClearanceWithinLimit() {
      return hasValidRequestedClearance() &&
        (
          !('clearanceLevel' in request.resource.data) ||
          request.resource.data.clearanceLevel <= maxClearanceForActor()
        );
    }

    function hasSafeDisplayName() {
      return !('displayName' in request.resource.data) ||
        (
          request.resource.data.displayName is string &&
          request.resource.data.displayName.size() > 0 &&
          request.resource.data.displayName.size() <= 50 &&
          request.resource.data.displayName.matches('^[^<>`]+$')
        );
    }

    // ═══ ISSUE 4 FIX: Field Injection Prevention ═══
    // Whitelist allowed fields for pages and similar content
    function hasSafePageFields() {
      let allowedKeys = [
        'id', 'slug', 'title', 'type', 'tags', 'status', 'html', 'css',
        'htmlContent', 'cssContent', 'clearanceLevel', 'authorUid', 'authorEmail', 
        'authorName', 'updatedAt', 'createdAt', 'submittedAt', 'approvedAt', 
        'approvedBy', 'anomalyId', 'anomalySubtype', 'anomalySubtypeLabel', 'anomalyListKey',
        'imageUrls', 'mediaUrls', 'excerpt'
      ];
      return request.resource.data.keys().hasOnly(allowedKeys);
    }

    function hasSafeSubmissionFields() {
      let allowedKeys = [
        'id', 'slug', 'title', 'type', 'tags', 'status', 'html', 'css',
        'htmlContent', 'cssContent', 'clearanceLevel', 'authorUid', 'authorEmail', 
        'authorName', 'updatedAt', 'createdAt', 'submittedAt',
        'anomalyId', 'anomalySubtype', 'anomalySubtypeLabel', 'anomalyListKey',
        'imageUrls', 'mediaUrls', 'imageAssets', 'mediaAssets',
        'docBlocks', 'currentMode', 'currentTemplate', 'subsectionCounters'
      ];
      return request.resource.data.keys().hasOnly(allowedKeys);
    }

    // ═══ ISSUE 4 FIX: Audit Trail for Sensitive Changes ═══
    // Require audit fields for role changes (should only come from server APIs)
    function hasRoleChangeAuditTrail() {
      return ('roleChangedBy' in request.resource.data) &&
        ('roleChangedAt' in request.resource.data) &&
        request.resource.data.roleChangedBy is string &&
        request.resource.data.roleChangedAt is timestamp;
    }

    // ═══ ISSUE 4 FIX: Clearance Level Authorization ═══
    // Only admins can change clearance level, and only up to their max clearance
    function isClearanceLevelChange() {
      return 'clearanceLevel' in request.resource.data &&
        ('clearanceLevel' in resource.data ? resource.data.clearanceLevel != request.resource.data.clearanceLevel : true);
    }

    function canModifyClearanceLevel() {
      return (isClearanceLevelChange() && canManageUsersRoles() && requestedClearanceWithinLimit()) ||
        !isClearanceLevelChange();
    }
    }

    function isValidRoleVal(roleVal) {
      return (roleVal is string) && (
        roleVal == 'owner' || 
        roleVal == 'chief_administrator' || roleVal == 'deputy_chief_administrator' || roleVal == 'senior_administrator' || roleVal == 'administrator' ||
        roleVal == 'chief_of_moderation' || roleVal == 'deputy_chief_of_moderation' || roleVal == 'senior_moderator' || roleVal == 'moderator' ||
        roleVal == 'contributor' || roleVal == 'site_member' || roleVal == 'newbie' ||
        roleVal == 'admin' || roleVal == 'chief_admin' || roleVal == 'junior_admin' || roleVal == 'junior_moderator' || roleVal == 'user' || roleVal == 'guest'
      );
    }

    // Prevent direct role field modification on client - enforce via API only
    function isRoleChangeRequest() {
      return 'role' in request.resource.data && 
        ('role' in resource.data ? resource.data.role != request.resource.data.role : true);
    }

    // Check if request includes audit trail fields (only server can set these)
    function hasAuditFields() {
      return ('roleChangedBy' in request.resource.data) ||
        ('roleChangedAt' in request.resource.data) ||
        ('roleChangeReason' in request.resource.data);
    }
    // Contributor revocations must go through server APIs with abuse-rate checks.
    function isClientContributorRevocation() {
      let currentRole = ('role' in resource.data && resource.data.role is string)
        ? resource.data.role
        : '';
      let nextRole = ('role' in request.resource.data && request.resource.data.role is string)
        ? request.resource.data.role
        : currentRole;

      let currentAccess = ('submissionAccess' in resource.data)
        ? resource.data.submissionAccess == true
        : false;
      let nextAccess = ('submissionAccess' in request.resource.data)
        ? request.resource.data.submissionAccess == true
        : currentAccess;

      let currentGranted = ('contributorGranted' in resource.data)
        ? resource.data.contributorGranted == true
        : false;
      let nextGranted = ('contributorGranted' in request.resource.data)
        ? request.resource.data.contributorGranted == true
        : currentGranted;

      let nextStatusRevoked = ('submissionAccessStatus' in request.resource.data) &&
        request.resource.data.submissionAccessStatus == 'revoked';
      let hasRevokeStamp = ('roleRevokedBy' in request.resource.data) ||
        ('roleRevokedAt' in request.resource.data);

      return (currentRole == 'contributor' && nextRole == 'user') ||
        (currentAccess && !nextAccess) ||
        (currentGranted && !nextGranted) ||
        nextStatusRevoked ||
        hasRevokeStamp;
    }

    // Check if the Archivist has delegated a specific permission to admins.
    // Returns true if the config/permissions doc has the given key set to true.
    function adminHasDelegation(permissionKey) {
      return isAdminUser() &&
        exists(/databases/$(database)/documents/config/permissions) &&
        (permissionKey in get(/databases/$(database)/documents/config/permissions).data) &&
        get(/databases/$(database)/documents/config/permissions).data[permissionKey] == true;
    }

    match /users/{userId} {
      // ISSUE 4 FIX: Reads restricted to admins or self
      allow read: if canManageUsersRoles() || isSelf(userId);
      
      // Allow create for self (registration) or admins
      allow create: if (canManageUsersRoles() || isSelf(userId)) &&
        !request.resource.data.keys().hasAny(['level', 'isOwner', 'contributorGranted', 'roleChangedBy', 'roleChangedAt']) &&
        hasSafeDisplayName() &&
        canModifyClearanceLevel() &&
        (!('role' in request.resource.data) || isValidRoleVal(request.resource.data.role));
      
      // Allow create for moderators with field restrictions
      allow create: if canApproveEditorAccessOnUsersDoc() &&
        hasEditorApprovalCreateFields() &&
        !request.resource.data.keys().hasAny(['level', 'isOwner', 'contributorGranted']) &&
        hasSafeDisplayName() &&
        canModifyClearanceLevel() &&
        (!('role' in request.resource.data) || isValidRoleVal(request.resource.data.role));
      
      // Allow updates: admins can update everything, users can update safe fields only
      allow update: if (canManageUsersRoles() && 
        !isClientContributorRevocation() && 
        (!('role' in request.resource.data) || isValidRoleVal(request.resource.data.role)) &&
        canModifyClearanceLevel() &&
        (isRoleChangeRequest() ? hasRoleChangeAuditTrail() : true)) ||
        
        (canApproveEditorAccessOnUsersDoc() && 
         hasEditorApprovalUpdateFields() &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['level', 'isOwner', 'contributorGranted']) &&
         !isClientContributorRevocation() && 
         (!('role' in request.resource.data) || isValidRoleVal(request.resource.data.role)) &&
         canModifyClearanceLevel()) ||
        
        (isSelf(userId) &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['level', 'isOwner', 'contributorGranted', 'role', 'clearanceLevel', 'roleChangedBy', 'roleChangedAt']) &&
         hasSafeDisplayName());
      
      allow delete: if canManageUsersRoles();
    }

    match /editorApplications/{applicationId} {
      // ISSUE 4 FIX: Admin only read/write with authentication required
      allow read: if canModerate() && isSignedIn();
      allow create, update, delete: if canModerate() && isSignedIn();
    }

    match /applications/{applicationId} {
      // ISSUE 4 FIX: Read restricted to moderators or document owner, authentication required
      allow read: if ((canModerate() && isSignedIn()) || (isSignedIn() && request.auth.uid == applicationId));
      allow create, update: if ((isSignedIn() && request.auth.uid == applicationId) || (canModerate() && isSignedIn()));
      allow delete: if canModerate() && isSignedIn();
    }

    match /pages/{pageId} {
      // ISSUE 4 FIX: Read protection for public content
      allow read: if canReadPublicContent();
      
      // ISSUE 4 FIX: Field validation and clearance level checks
      allow create, update: if canCreateEditPages() && 
        requestedClearanceWithinLimit() &&
        hasSafePageFields();
      
      allow delete: if canModerate();

      // Upvotes subcollection - allow users to upvote/unvote anomalies via the API
      match /upvotes/{userId} {
        allow read: if canManageUsersRoles() || (isSignedIn() && request.auth.uid == userId);
        allow create, delete: if canInteractWithContent() && request.auth.uid == userId;
        allow update: if false;
      }
    }

    match /submissions/{subId} {
      // ISSUE 4 FIX: Author UID must match token, clearance checked, fields validated
      allow create: if canInteractWithContent() &&
        request.resource.data.authorUid == request.auth.uid &&
        (request.resource.data.status == 'pending' || request.resource.data.status == 'draft') &&
        requestedClearanceWithinLimit() &&
        hasSafeSubmissionFields();
      
      // ISSUE 4 FIX: Read restricted to moderators or document author
      allow read: if canModerate() || (isSignedIn() && resource.data.authorUid == request.auth.uid);
      
      // ISSUE 4 FIX: Update restricted to moderators or author (drafts only), with field validation
      allow update: if (canModerate() && 
        requestedClearanceWithinLimit() &&
        hasSafeSubmissionFields()) ||
        (canInteractWithContent() &&
         resource.data.authorUid == request.auth.uid &&
         resource.data.status == 'draft' &&
         request.resource.data.status == 'draft' &&
         requestedClearanceWithinLimit() &&
         hasSafeSubmissionFields());
      
      allow delete: if canModerate();
    }

    match /artworks/{artworkId} {
      // ISSUE 4 FIX: Public read, field validation on write
      allow read: if canReadPublicContent();
      allow create, update, delete: if canModerate() && hasSafePageFields();
    }

    match /news/{newsId} {
      // ISSUE 4 FIX: Public read, field validation on write
      allow read: if canReadPublicContent();
      allow create, update, delete: if canModerate() && hasSafePageFields();
    }

    match /config/{docId} {
      // ISSUE 4 FIX: All signed-in users can read config (needed for role resolution and ESD state)
      allow read: if isSignedIn();
      // ISSUE 4 FIX: Only admins can write config
      allow write: if canManageUsersRoles() && isSignedIn();
    }

    match /submissions_meta/{uid} {
      // ISSUE 4 FIX: Admin only, authentication required
      allow read, write: if canModerate() && isSignedIn();
    }

    match /legacySheets/{sheetId} {
      // ISSUE 4 FIX: Public read, admin write with authentication required
      allow read: if canReadPublicContent();
      allow create, update, delete: if ((isOwnerUser() && isSignedIn()) || ((canModerate() && isSignedIn()) && adminHasDelegation('adminCanEditLegacy')));
    }

    // Reports collections - ISSUE 4 FIX: Only authenticated users can create, only mods can read/manage
    match /commentReports/{reportId} {
      allow read: if canModerate();
      allow create: if canInteractWithContent() && isSignedIn();
      allow update, delete: if false; // Reports are immutable once created
    }

    match /dmReports/{reportId} {
      allow read: if canModerate();
      allow create: if canInteractWithContent() && isSignedIn();
      allow update, delete: if false; // Reports are immutable once created
    }

    match /pageReports/{reportId} {
      allow read: if canModerate();
      allow create: if canInteractWithContent() && isSignedIn();
      allow update, delete: if false; // Reports are immutable once created
    }

    match /reports/{reportId} {
      allow read: if canModerate();
      allow create: if canInteractWithContent() && isSignedIn();
      allow update: if canModerate();
      allow delete: if false; // Reports cannot be deleted, only moderated
    }
  }
}
