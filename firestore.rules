rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isBootstrapOwner() {
      return isSignedIn() && (
        request.auth.token.email == 'jaimejoselaureano@gmail.com' ||
        request.auth.token.email == 'dudefromalhiem@gmail.com'
      );
    }

    function isOwnerFromRolesDoc() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/config/roles) &&
        ('owners' in get(/databases/$(database)/documents/config/roles).data) &&
        request.auth.token.email in get(/databases/$(database)/documents/config/roles).data.owners;
    }

    function isOwnerUser() {
      return isSignedIn() && (isBootstrapOwner() || isOwnerFromRolesDoc());
    }

    function isAdminUser() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true) ||
        isBootstrapOwner() ||
        isOwnerFromRolesDoc()
      );
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Check if the owner has delegated a specific permission to admins.
    // Returns true if the config/permissions doc has the given key set to true.
    function adminHasDelegation(permissionKey) {
      return isAdminUser() &&
        exists(/databases/$(database)/documents/config/permissions) &&
        (permissionKey in get(/databases/$(database)/documents/config/permissions).data) &&
        get(/databases/$(database)/documents/config/permissions).data[permissionKey] == true;
    }

    match /users/{userId} {
      allow read: if isAdminUser() || isSelf(userId);
      allow create: if (isAdminUser() || isSelf(userId)) && !request.resource.data.keys().hasAny(['isAdmin']);
      allow update: if isAdminUser() || (isSelf(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin']));
      allow delete: if isAdminUser();
    }

    match /pages/{pageId} {
      // Allow reads for admins, approved pages, or pages without a status field (legacy/seed pages)
      allow read: if isAdminUser() || resource.data.status == 'approved' || !('status' in resource.data);
      allow create, update, delete: if isAdminUser();
    }

    match /submissions/{subId} {
      allow create: if isSignedIn() &&
        request.resource.data.authorUid == request.auth.uid &&
        (request.resource.data.status == 'pending' || request.resource.data.status == 'draft');
      allow read: if isAdminUser() || (isSignedIn() && resource.data.authorUid == request.auth.uid);
      // Allow the original author to update their own draft submissions
      allow update: if isAdminUser() ||
        (isSignedIn() &&
         resource.data.authorUid == request.auth.uid &&
         resource.data.status == 'draft' &&
         request.resource.data.status == 'draft');
      allow delete: if isAdminUser();
    }

    match /artworks/{artworkId} {
      allow read: if true;
      allow create, update, delete: if isAdminUser();
    }

    match /news/{newsId} {
      allow read: if true;
      allow create, update, delete: if isAdminUser();
    }

    match /config/{docId} {
      // All signed-in users can read config (needed for role resolution and ESD state)
      allow read: if isSignedIn();
      allow write: if isAdminUser();
    }

    match /submissions_meta/{uid} {
      allow read, write: if isAdminUser();
    }

    match /legacySheets/{sheetId} {
      allow read: if true;
      // Owner can always write. Admins can write ONLY if the owner has delegated this permission.
      allow create, update, delete: if isOwnerUser() || adminHasDelegation('adminCanEditLegacy');
    }
  }
}
