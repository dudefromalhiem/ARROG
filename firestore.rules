rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isBootstrapOwner() {
      return isSignedIn() && (
        request.auth.token.email == 'jaimejoselaureano@gmail.com' ||
        request.auth.token.email == 'dudefromalhiem@gmail.com'
      );
    }

    function isOwnerFromRolesDoc() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/config/roles) &&
        ('owners' in get(/databases/$(database)/documents/config/roles).data) &&
        request.auth.token.email in get(/databases/$(database)/documents/config/roles).data.owners;
    }

    function isAdminUser() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true) ||
        isBootstrapOwner() ||
        isOwnerFromRolesDoc()
      );
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isAdminUser() || isSelf(userId);
      allow create: if (isAdminUser() || isSelf(userId)) && !request.resource.data.keys().hasAny(['isAdmin']);
      allow update: if isAdminUser() || (isSelf(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin']));
      allow delete: if isAdminUser();
    }

    match /pages/{pageId} {
      allow read: if isAdminUser() || (resource.data.status == 'approved');
      allow create, update, delete: if isAdminUser();
    }

    match /submissions/{subId} {
      allow create: if isSignedIn() &&
        request.resource.data.authorUid == request.auth.uid &&
        (request.resource.data.status == 'pending' || request.resource.data.status == 'draft');
      allow read, update, delete: if isAdminUser();
    }

    match /artworks/{artworkId} {
      allow read: if true;
      allow create, update, delete: if isAdminUser();
    }

    match /news/{newsId} {
      allow read: if true;
      allow create, update, delete: if isAdminUser();
    }

    match /config/{docId} {
      allow read, write: if isAdminUser();
    }

    match /submissions_meta/{uid} {
      allow read, write: if isAdminUser();
    }
  }
}
