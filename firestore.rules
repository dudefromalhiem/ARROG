rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner';
    }

    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        isOwner()
      );
    }

    // ── Users collection ──────────────────────────────────
    match /users/{userId} {
      // Anyone signed in can read user profiles
      allow read: if isSignedIn();
      // Users can create their own profile on first login
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Only owner can update roles; users can update own non-role fields
      allow update: if isOwner() ||
        (isSignedIn() && request.auth.uid == userId &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      allow delete: if isOwner();
    }

    // ── Pages (Anomalies, Tales, etc.) ────────────────────
    match /pages/{pageId} {
      allow read: if true; // Public wiki
      allow create, update, delete: if isAdmin();
    }

    // ── Submissions (User-created pages pending review) ───
    match /submissions/{subId} {
      // Admins can read all; users can read their own
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.authorUid == request.auth.uid);
      // Any authenticated user can create a submission
      allow create: if isSignedIn() &&
        request.resource.data.authorUid == request.auth.uid &&
        request.resource.data.status == 'pending';
      // Only admins can update (approve/reject)
      allow update: if isAdmin();
      // Admins can delete; authors can delete their own pending submissions
      allow delete: if isAdmin() ||
        (isSignedIn() && resource.data.authorUid == request.auth.uid &&
         resource.data.status == 'pending');
    }

    // ── Artworks ──────────────────────────────────────────
    match /artworks/{artworkId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── News ──────────────────────────────────────────────
    match /news/{newsId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Configuration (Including Roles) ───────────────────
    match /config/{docId} {
      allow read: if true; // Roles must be public so the app can resolve permissions
      allow write: if isOwner(); // Only the owner can modify roles
    }
  }
}
