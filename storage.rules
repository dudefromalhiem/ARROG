rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public read for all files (artwork images, submissions, etc.)
    match /{allPaths=**} {
      allow read: if true;
    }

    // Only admins/owner can upload to artworks
    match /artworks/{fileName} {
      allow write: if request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'owner'];
    }

    // Only admins/owner can upload to general uploads
    match /uploads/{fileName} {
      allow write: if request.auth != null &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'owner'];
    }

    // Authenticated users can upload images to their own submissions folder
    // Max 5MB, must be image type
    match /submissions/{userId}/{fileName} {
      allow write: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.size < 5 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }
  }
}
