rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAllowedImageUpload() {
      return request.resource.size <= 10 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*') &&
        request.resource.contentType in ['image/png', 'image/jpeg', 'image/gif', 'image/webp'];
    }

    function isAllowedAudioUpload() {
      return request.resource.size <= 10 * 1024 * 1024 &&
        request.resource.contentType.matches('audio/.*') &&
        request.resource.contentType in ['audio/mpeg', 'audio/wav', 'audio/mp4', 'audio/aac', 'audio/ogg', 'audio/webm'];
    }

    function isAllowedVideoUpload() {
      return request.resource.size <= 25 * 1024 * 1024 &&
        request.resource.contentType.matches('video/.*') &&
        request.resource.contentType in ['video/mp4', 'video/webm', 'video/quicktime', 'video/ogg', 'video/x-matroska'];
    }

    match /{allPaths=**} {
      allow read: if true;
    }

    match /artworks/{allPaths=**} {
      allow write: if isSignedIn() && isAllowedImageUpload();
    }

    match /uploads/{userId}/{allPaths=**} {
      allow write: if isSignedIn() &&
        request.auth.uid == userId &&
        (isAllowedImageUpload() || isAllowedAudioUpload() || isAllowedVideoUpload());
    }

    match /submissions/{submissionId}/{allPaths=**} {
      // Backend API (Firebase Admin SDK) writes large content here
      // Client-side reads are allowed for authenticated users
      allow read: if true;
      // Do NOT allow client-side writes here. The Admin SDK (server) bypasses
      // security rules, so server-side code should write content to this
      // path. Prevent any client from writing to /submissions/ to avoid abuse.
      allow write: if false;
    }
  }
}
