rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAllowedImageUpload() {
      return request.resource.size <= 2 * 1024 * 1024 &&
        request.resource.contentType in ['image/png', 'image/jpeg', 'image/gif', 'image/webp'];
    }

    match /{allPaths=**} {
      allow read: if true;
    }

    match /artworks/{fileName} {
      allow write: if isSignedIn() && isAllowedImageUpload();
    }

    match /uploads/{userId}/{fileName} {
      allow write: if isSignedIn() &&
        request.auth.uid == userId &&
        isAllowedImageUpload();
    }
  }
}
